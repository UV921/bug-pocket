generator client {
  provider = "prisma-client"
  output = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  refreshTokens RefreshToken[]
  bugs Bug[]

}
model RefreshToken {
  id        String   @id @default(cuid())
  token     String
  userId    String
  createdAt DateTime @default(now())
  expireAt DateTime 
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

  enum Severity {
    LOW
    MEDIUM
    HIGH
    CRITICAL
  }
model Bug{
  id        String   @id @default(cuid())
  title     String
  description String
  reproductionSteps String
  userId String
  codesnippit String
  codinglanguage String
  severity Severity
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])



  

  
  
  
}